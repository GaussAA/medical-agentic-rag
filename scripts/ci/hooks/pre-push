#!/usr/bin/env bash
# pre-push 钩子 —— 推送前真实链路冒烟（P2-④ 本地门禁）
# 行为约定：
#   · CI 环境（CI 变量非空）→ 直接放行（CI 已有纯逻辑门禁，避免重复卡点）
#   · 本环境无真库（脚本退出码 2）→ 视为允许推送（开发机/CI 宿主机无 KB）
#   · 真实链路故障（脚本退出码 1）→ 阻断推送，强制先修检索/FTS/引擎链路
set -uo pipefail

# CI 环境跳过（GitHub Actions / 其他 CI 均会注入 CI=true）
if [ -n "${CI:-}" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
  echo "[pre-push] 未处于 git 仓库，跳过真实链路冒烟。"
  exit 0
fi
cd "$ROOT" || exit 0

if command -v npm >/dev/null 2>&1; then
  npm run test:real-link --silent
  code=$?
elif command -v node >/dev/null 2>&1; then
  node scripts/ci/smoke/smoke-real-link.mjs
  code=$?
else
  echo "[pre-push] 未找到 node/npm，跳过真实链路冒烟。"
  exit 0
fi

if [ "$code" -eq 2 ]; then
  echo "[pre-push] 真实链路冒烟跳过（本环境无真库），允许推送。"
  exit 0
fi
if [ "$code" -ne 0 ]; then
  echo "[pre-push] ✗ 真实链路冒烟失败（exit $code），已阻断推送。请排查 FTS/检索/引擎链路后再 push。"
  exit 1
fi
echo "[pre-push] ✓ 真实链路冒烟通过。"
exit 0
