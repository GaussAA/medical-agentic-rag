# ========== 忽略 Pi 源码（单独维护） ==========
pi/

# ========== 忽略 API Key 配置 ==========
start.bat
start.ps1
.env
.env.local

# .env.example 需要入仓作为模板，不忽略
!.env.example

# ========== 忽略 Node 依赖 ==========
node_modules/
.pnpm-store/

# ========== 忽略运行时数据 ==========
.pi/agent/
.pi/knowledge/
.pi/cache/
# 患者画像含 PHI（个人健康信息，已 AES-256-GCM 加密），仍绝对不入仓
.pi/patient-profile.json
# PHI 加密密钥（自动生成），绝对不入仓
.pi/.data-key
# 知识库来源登记表（含运行元数据/时间戳）+ 快照
kb-sources.json
.pi/kb-snapshots/
# 原始知识库（方案B：弃MD中间层，原始PDF/DOCX为唯一真相源；可经管线重建，体积大不入仓）
medical-raw/
medical-raw-txt/
# 故障转移选择结果（运行期生成）
.pi/failover-selection.json
# 业务日志 + 合规审计日志（audit-*.ndjson）
logs/
backups/

# 但保留自定义扩展文件
!.pi/extensions/

# ========== 忽略测试会话导出 ==========
pi-session-*.html

# ========== 忽略编译产物 ==========
scripts/.patient-profile-compiled.mjs

# ========== 忽略系统文件 ==========
.DS_Store
Thumbs.db
*.log

# ========== 忽略 IDE 配置 ==========
.idea/
.vscode/
*.swp
*.swo

# ========== 忽略 WorkBuddy 元数据 ==========
.workbuddy/

# ========== 忽略其他 ==========
docs/
