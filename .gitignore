# ========== 忽略 Pi 源码（单独维护） ==========
pi/
# 早期本地知识库数据残留（KB 已迁至用户 HOME 的 .pi/knowledge，此处为废弃本地副本，防污染）
.pi-knowledge/

# ========== 忽略 API Key 配置 ==========
start.bat
start.ps1
.env
.env.local

# .env.example 需要入仓作为模板，不忽略
!.env.example

# ========== 忽略 Node 依赖 ==========
node_modules/
.pnpm-store/

# ========== 忽略运行时数据 ==========
# 注意：知识库实际位于用户 HOME 的 .pi/knowledge（跨项目共享，不在本仓库内）。
# 以下 .pi/agent/ 与 .pi/knowledge/ 为防御性预置——当前项目内并无此子目录，
# 若未来本仓库内生成对应目录则自动忽略，避免误提交运行期数据。
.pi/agent/
.pi/knowledge/
.pi/cache/
# 会话历史（含对话内容，可能含 PHI，绝对不入仓）
.pi/sessions/
# 归档会话历史（含对话内容，可能含 PHI，绝对不入仓）
.pi/archive/
# 患者画像含 PHI（个人健康信息，已 AES-256-GCM 加密），仍绝对不入仓
.pi/patient-profile.json
# PHI 加密密钥（自动生成），绝对不入仓
.pi/.data-key
# 审计密钥（自动生成），绝对不入仓
.pi/.audit-key
# 对话运行时状态（自动生成，每轮刷新）
.pi/conversation-state.json
# 知识库来源登记表（含运行元数据/时间戳）+ 快照（现位于 data/kb/ 下）
kb-sources.json
.pi/kb-snapshots/
# ========== 知识库数据 — 原始文档（不入仓，可经管线重建） ==========
data/raw/
data/raw-bak/
data/raw-txt/
# 故障转移选择结果（运行期生成）
.pi/failover-selection.json
# API 服务运行时 PID（运行期生成）
.pi/api.pid
# Windows 保留设备名误建文件（须 WSL 删除，常规 API 无法处理）
nul
# 业务日志 + 合规审计日志（audit-*.ndjson）+ 运行时日志
.pi/logs/
# 旧日志目录残留（已迁至 .pi/logs/，可清理）
logs/
backups/

# 但保留自定义扩展文件
!.pi/extensions/

# pi-llm-wiki 安装包依赖（19MB，可重建，不入仓）
.pi/npm/node_modules/

# LLM Wiki 知识库（11MB/759页，可从 data/raw-txt/ 重建，不入仓）
.llm-wiki/

# ========== 忽略测试会话导出 ==========
pi-session-*.html

# ========== 忽略编译产物 ==========
scripts/.patient-profile-compiled.mjs

# ========== 忽略系统文件 ==========
.DS_Store
Thumbs.db
*.log

# ========== 忽略 IDE 配置 ==========
.idea/
.vscode/
*.swp
*.swo

# ========== 忽略 WorkBuddy 元数据 ==========
.workbuddy/

# ========== 忽略其他 ==========
# 归档：自动爬取中被判定为「废止/纯扫描无文本层」等不可入库的原始文件（移出扫描目录，留档可溯）
_archived_raw_doc/
# 信息图生成产物（generate_medical_infographic 工具输出，可重建，不入仓）
data/infographics/
docs/*
# 合规治理交付件（E3）刻意入仓，不被 docs 忽略吞掉
!docs/compliance/
# shell 重定向残留（如 `> dev/null` 勿误写为 `> dev/null`）
dev/

# ========== 忽略测试报告产物（可重建，不入仓） ==========
# 注意：须用 tests/reports/**（仅排内容、不排目录本身），
# 否则父目录被整目录排除时，下方否定无法重新纳入基线文件（git 限制）。
tests/reports/**
# 但保留基线 JSON（CI 门禁用，确保 PR 级质量卡点可独立运行）
!tests/reports/baseline.json

# ========== 三层知识库目录职责说明 ==========
# data/raw/    真相源层 —— 原始 PDF/DOCX（411MB，不可入仓），pi-knowledge 摄取源
# data/raw-txt/ 文本缓存层 —— pdftotext 提取的归一化纯文本（17MB，可重建不入仓）
# data/kb/     索引层 —— 派生 JSON 索引（433KB，故意入仓保 clone 即用）
#
# 三层的单向数据流：data/raw/ → pdftotext → data/raw-txt/ → parser → data/kb/ JSON
# 不宜合并：生命周期不同、入仓策略不同、工具职责不同
# ========================================================
# data/kb/ 故意不忽略：其下 .outline.json/.guide-index.json/.knowledge-graph.json
# 为派生索引，但因上游真相源 data/raw/ 刻意不入库，故索引入仓以保证 clone 后系统可直接可用。
# 但图谱 SQLite（.knowledge-graph.db，由 JSON 构建的二分图多跳索引）属可重建派生产物，忽略：
data/kb/.knowledge-graph.db
data/kb/.knowledge-graph.db-wal
data/kb/.knowledge-graph.db-shm
# docs/ 下 2 份早期误入仓的生成物报告（全景验收报告.html、抓取管线规划.md）已于本回合
# 经 git rm --cached 清理出索引，磁盘保留，令 docs/ 忽略规则彻底生效。

# 嵌入评测产物（172+ MB 浮点数缓存 + 报告，可重建，不入仓）
data/embed-cache*
data/*-report.json

# 图片提取产物（可重建，不入仓）
data/kb/figures/

# ========== 收拢 WIP 时补充的忽略项（2026-07-19） ==========
# 前端 UI 由协作同僚维护，源码不入库（其 node_modules 已受全局规则忽略）
frontend/
# Playwright 测试缓存目录（运行期生成，非源码）
.playwright-cli/
# 临时截图（md-*.png 为前端预览截图，非源码）
md-*.png

