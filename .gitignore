# ========== 忽略 Pi 源码（单独维护） ==========
pi/
# 早期本地知识库数据残留（KB 已迁至用户 HOME 的 .pi/knowledge，此处为废弃本地副本，防污染）
.pi-knowledge/

# ========== 忽略 API Key 配置 ==========
start.bat
start.ps1
.env
.env.local

# .env.example 需要入仓作为模板，不忽略
!.env.example

# ========== 忽略 Node 依赖 ==========
node_modules/
.pnpm-store/

# ========== 忽略运行时数据 ==========
# 注意：知识库实际位于用户 HOME 的 .pi/knowledge（跨项目共享，不在本仓库内）。
# 以下 .pi/agent/ 与 .pi/knowledge/ 为防御性预置——当前项目内并无此子目录，
# 若未来本仓库内生成对应目录则自动忽略，避免误提交运行期数据。
.pi/agent/
.pi/knowledge/
.pi/cache/
# 患者画像含 PHI（个人健康信息，已 AES-256-GCM 加密），仍绝对不入仓
.pi/patient-profile.json
# PHI 加密密钥（自动生成），绝对不入仓
.pi/.data-key
# 对话运行时状态（自动生成，每轮刷新）
.pi/conversation-state.json
# 知识库来源登记表（含运行元数据/时间戳）+ 快照
kb-sources.json
.pi/kb-snapshots/
# 原始知识库（方案B：弃MD中间层，原始PDF/DOCX为唯一真相源；可经管线重建，体积大不入仓）
medical-raw/
medical-raw-txt/
# 故障转移选择结果（运行期生成）
.pi/failover-selection.json
# 业务日志 + 合规审计日志（audit-*.ndjson）
logs/
backups/

# 但保留自定义扩展文件
!.pi/extensions/

# ========== 忽略测试会话导出 ==========
pi-session-*.html

# ========== 忽略编译产物 ==========
scripts/.patient-profile-compiled.mjs

# ========== 忽略系统文件 ==========
.DS_Store
Thumbs.db
*.log

# ========== 忽略 IDE 配置 ==========
.idea/
.vscode/
*.swp
*.swo

# ========== 忽略 WorkBuddy 元数据 ==========
.workbuddy/

# ========== 忽略其他 ==========
# 归档：自动爬取中被判定为「废止/纯扫描无文本层」等不可入库的原始文件（移出扫描目录，留档可溯）
_archived_raw_doc/
docs/

# ========== 忽略测试报告产物（可重建，不入仓） ==========
tests/reports/

# ========== 显式保留项说明（不忽略，特此标注以免误加忽略规则） ==========
# medical-knowlegde-base/ 故意不忽略：其下 .outline.json/.guide-index.json/.knowledge-graph.json
# 为派生索引，但因上游真相源 medical-raw/ 刻意不入库，故索引入仓以保证 clone 后系统可直接可用。
# docs/ 下 2 份早期误入仓的生成物报告（全景验收报告.html、抓取管线规划.md）已于本回合
# 经 git rm --cached 清理出索引，磁盘保留，令 docs/ 忽略规则彻底生效。
