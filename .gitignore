# ========== 忽略 Pi 源码（单独维护） ==========
pi/

# ========== 忽略 API Key 配置 ==========
start.bat
start.ps1
.env
.env.local

# .env.example 需要入仓作为模板，不忽略
!.env.example

# ========== 忽略 Node 依赖 ==========
node_modules/
.pnpm-store/

# ========== 忽略运行时数据 ==========
.pi/agent/
.pi/knowledge/
logs/
backups/

# 但保留自定义扩展文件
!.pi/extensions/

# ========== 忽略测试会话导出 ==========
pi-session-*.html

# ========== 忽略系统文件 ==========
.DS_Store
Thumbs.db
*.log

# ========== 忽略 IDE 配置 ==========
.idea/
.vscode/
*.swp
*.swo

# ========== 忽略 WorkBuddy 元数据 ==========
.workbuddy/
