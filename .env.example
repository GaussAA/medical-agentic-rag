# ========================================
# 医疗 Agentic RAG - 环境变量配置模板
# 复制本文件为 .env 并填入你的真实 Key
# cp .env.example .env
# ========================================

# ========================================
# 一、LLM API Keys（至少配一个）
# ========================================

# 【免费主力】商汤日日新（sensenova-6.7-flash-lite）
# 免费额度：1500次/5小时。项目首选免费模型。
# 获取：https://platform.sensenova.cn/
SENSENOVA_API_KEY=YOUR_SENSENOVA_API_KEY

# 【备用付费】DeepSeek 直连通道（deepseek-v4-flash）
# 通过 Pi 原生 provider 直连 api.deepseek.com，替代 sensenova 代理通道
# 获取：https://platform.deepseek.com/
# DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# 【兜底】Agnes AI（付费）
# AGNES_API_KEY=YOUR_AGNES_API_KEY

# 【本地模型】LM Studio（localhost:1234）
# 配置后自动启用 gemma-4-e2b 等本地模型，无需 API Key
# 服务地址：http://localhost:1234/v1

# ========================================
# 二、Web 搜索（任一启用即可获得网络搜索能力）
# ========================================

# Brave Search（推荐，免费 2000 次/月）
# 获取：https://brave.com/search/api/
# BRAVE_API_KEY=YOUR_BRAVE_API_KEY

# Tavily Search（AI 原生搜索，免费 1000 次/月）
# 获取：https://tavily.com/
# TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# Exa Search（语义搜索）
# 获取：https://exa.ai/
# EXA_API_KEY=YOUR_EXA_API_KEY

# Perplexity Search
# 获取：https://docs.perplexity.ai/
# PERPLEXITY_API_KEY=YOUR_PERPLEXITY_API_KEY

# OpenAI Search（需支持搜索的模型）
# 获取：https://platform.openai.com/
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ========================================
# 三、部署与缓存
# ========================================

# Redis 连接串（配置后自动启用三级缓存：内存→文件→Redis）
# K8s 多 Pod 场景下共享缓存，减少 40-60% 重复检索
# REDIS_URL=redis://redis-service:6379

# 缓存后端选择：auto（默认，有 Redis 则用）| redis（强制）| file（禁用）
# CACHE_BACKEND=auto

# 检索缓存 TTL（秒，默认 600=10 分钟）
# RETRIEVAL_CACHE_TTL=600

# 检索缓存最大条目数（默认 500）
# RETRIEVAL_CACHE_MAX_ENTRIES=500

# ========================================
# 四、评估与监控
# ========================================

# 在线评估采样率（0-1，默认 0.05=5%）
# 生产流量按比例自动采样，异步 LLM-Judge 评分
# ONLINE_EVAL_SAMPLE_RATE=0.05

# 上下文压缩 token 预算（默认 12000）
# CONTEXT_BUDGET_TOKENS=12000

# 路由置信度下限（低于此值视为低置信，默认 12）
# ROUTE_CONFIDENCE_MIN=12

# ========================================
# 五、密钥（PHI 加密 / 审计防篡改）
# ========================================

# 患者画像 AES-256-GCM 密钥（零信任：不硬编码，缺失则本地自动生成 .pi/.data-key）。
# 须恰好 32 字节：hex(64 位) 或 base64（约 44 字符）。
# 生成：openssl rand -hex 32（或留空走自动生成，仅适合单机本地）
PATIENT_DATA_KEY=

# 审计链 HMAC-SHA256 防篡改密钥（缺失则本地自动生成 .pi/.audit-key）。
# 须为 hex 字符串（推荐 64 位 = 32 字节）：openssl rand -hex 32
# 多实例/多机共享审计链时，须统一此密钥以确保哈希链可验证。
AUDIT_HMAC_KEY=

# ========================================
# 六、Pi-knowledge 配置
# ========================================

# 文件变更自动重索引（默认 true）
# PI_KNOWLEDGE_WATCH=true

# 重排序模型（已 patch 默认中文 bge-reranker-base）
# PI_KNOWLEDGE_RERANKER=Xenova/bge-reranker-base

# 引擎检索超时（毫秒，默认 20000=20s，超时熔断回退 BM25）
# ENGINE_TIMEOUT_MS=20000

# 软约束采信比例（默认 0.6，路由过滤集最高分 ≥ 全库最高分 × 此比例才采信）
# SOFT_CONSTRAINT_RATIO=0.6

# ========================================
# 七、代理（中国大陆用户按需开启）
# ========================================

# HTTPS_PROXY=http://127.0.0.1:7897
# HF_ENDPOINT=https://hf-mirror.com

# ========================================
# 八、Alertmanager 告警
# ========================================

# 告警推送目标（企业微信/飞书/钉钉 webhook、自建 notify 服务等）。
# 缺失则 alertmanager 回退至本地占位端点（能启动但不推送），务必填入真实 URL。
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.example.com/notify

# 告警级别（debug | info | warn | error，默认 warn）
# ALERT_LOG_LEVEL=warn

# ========================================
# 九、Grafana 与可观测性
# ========================================

# Grafana 管理员密码（docker-compose 部署用）
# GRAFANA_ADMIN_PASSWORD=admin

# Prometheus 指标端口（默认 9464）
# PROMETHEUS_PORT=9464

# ========================================
# 十、CI/CD 门禁阈值（可环境变量覆盖）
# ========================================

# 答案忠实度下限（默认 0.7，低于此值 CI 红）
# GATE_FAITH_MIN=0.7
# 安全分下限（默认 0.9）
# GATE_SAFETY_MIN=0.9
# 临床正确性下限（默认 0.8）
# GATE_CLINICAL_MIN=0.8
# 回答相关性下限（默认 0.8）
# GATE_RELEVANCE_MIN=0.8
# 引用召回率下限 %（默认 70）
# GATE_CITATION_MIN=70
# 越界拒答准确率（默认 100）
# GATE_REFUSAL_MIN=100
# 禁戒违例率上限 %（默认 0）
# GATE_FORBIDDEN_MAX=0
